COMPOSE_PROJECT_NAME=travel_booking

APP_ENV=development
TZ=Asia/Ho_Chi_Minh
TZ_OFFSET=+07:00

WP_HOME=http://localhost
WP_SITEURL=${WP_HOME}

WP_DEBUG=true
WP_DEBUG_LOG=/var/log/wp-debug.log
WP_DEBUG_DISPLAY=false
FORCE_SSL_ADMIN=false

AUTH_KEY=travel_booking_auth_key
SECURE_AUTH_KEY=travel_booking_secure_auth_key
LOGGED_IN_KEY=travel_booking_logged_in_key
NONCE_KEY=travel_booking_nonce_key
AUTH_SALT=travel_booking_auth_salt
SECURE_AUTH_SALT=travel_booking_secure_auth_salt
LOGGED_IN_SALT=travel_booking_logged_in_salt
NONCE_SALT=travel_booking_nonce_salt

WP_REDIS_DISABLED=false
WP_REDIS_PREFIX=travel_booking_

DB_HOST=mysql
DB_PORT=3306
DB_NAME=wordpress
DB_USER=wp_user
DB_PASSWORD=travel_booking_password
DB_ROOT_PASSWORD=travel_booking_root_password
DB_CHARSET=utf8mb4
DB_COLLATE=utf8mb4_unicode_ci

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=travel_booking_redis_password

PHP_MEMORY_LIMIT=512M
PHP_MAX_EXECUTION_TIME=120
PHP_UPLOAD_MAX_FILESIZE=64M
PHP_POST_MAX_SIZE=64M
PHP_SESSION_COOKIE_SECURE=0

NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
MYSQL_PORT=3306
PHPMYADMIN_PORT=8080